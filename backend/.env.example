# Copy to .env and adjust values

# CORS — add your Next.js production URL here
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Model
MODEL_PATH=../ml/model.pt

# Pipeline thresholds
YOLO_CONF_THRESHOLD=0.8
STRUCT_CONF_THRESHOLD=0.9

# Job TTL in seconds (1 hour default)
JOB_TTL=3600

# Set to true in development
DEBUG=false
